# ============================================================
# BAAM System I — Insurance Brokerage Platform
# Environment Variables — copy to .env.local and fill in values
#
# REQUIRED for Vercel deployment:
# Set ALL of these in Vercel Dashboard → Project Settings → Environment Variables
# Set for both "Preview" and "Production" environments
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com          # Update to real domain
NEXT_PUBLIC_DEFAULT_SITE=peerless-brokerage         # Default site ID
NODE_ENV=production                                  # Set automatically by Vercel

# ── Supabase (REQUIRED — site will not work without these) ───
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...    # Safe for browser (public)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...             # NEVER prefix with NEXT_PUBLIC_!
SUPABASE_STORAGE_BUCKET=media

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=minimum-32-character-random-string-here  # Generate: openssl rand -hex 32

# ── Email / Lead Notifications (REQUIRED for quote alerts) ───
RESEND_API_KEY=re_...
RESEND_FROM=noreply@yourdomain.com
QUOTE_NOTIFICATION_EMAIL=leads@yourdomain.com       # Where new quotes are sent
CONTACT_FALLBACK_TO=info@yourdomain.com

# ── Analytics (add after launch) ─────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX          # Google Analytics 4

# ── AI Features (optional) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# ── Stock Photos for Admin Media Browser (optional) ──────────
UNSPLASH_ACCESS_KEY=...
PEXELS_API_KEY=...

# ── Internal Security ─────────────────────────────────────────
INTERNAL_API_SECRET=random-internal-secret-string

# ── Blog Scheduler (optional) ────────────────────────────────
BLOG_PUBLISH_CRON_SECRET=random-cron-secret

# ============================================================
# SECURITY CHECKLIST before production:
# [ ] SUPABASE_SERVICE_ROLE_KEY does NOT start with NEXT_PUBLIC_
# [ ] JWT_SECRET is at least 32 characters
# [ ] RESEND_API_KEY is from a verified domain
# [ ] All secrets are different from development values
# ============================================================
